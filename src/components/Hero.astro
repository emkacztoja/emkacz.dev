---
import { profile } from '../data/profile';
---

<section id="top" class="relative isolate overflow-hidden pt-32 pb-20 sm:pt-44 sm:pb-32">
  <!-- Subtle grid backdrop -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10 [mask-image:radial-gradient(ellipse_at_top,black,transparent_70%)]"
  >
    <div
      class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.04)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.04)_1px,transparent_1px)] bg-[size:64px_64px]"
    ></div>
    <div
      data-parallax="0.18"
      class="absolute left-1/2 top-0 h-[420px] w-[820px] -translate-x-1/2 rounded-full opacity-60 blur-3xl will-change-transform"
      style="background: radial-gradient(closest-side, color-mix(in oklab, var(--color-accent) 35%, transparent), transparent 70%);"
    ></div>
  </div>

  <div class="mx-auto max-w-6xl px-6 sm:px-8">
    <!-- Eyebrow -->
    <div class="hero-rise hero-rise-d1 inline-flex items-center gap-2 rounded-full border border-line bg-white/[0.02] px-3 py-1 text-[12px] text-fog backdrop-blur">
      <span class="font-mono">~/portfolio</span>
      <span class="text-line-strong">·</span>
      <span class="font-mono">{profile.location}</span>
    </div>

    <!-- Headline -->
    <h1 class="hero-rise hero-rise-d2 mt-6 max-w-5xl text-[clamp(2.5rem,8vw,6rem)] font-semibold leading-[0.95] tracking-[-0.04em]">
      Coder, builder,
      <br />
      <span class="gradient-text">problem solver.</span>
    </h1>

    <!-- Subline -->
    <p class="hero-rise hero-rise-d3 mt-8 max-w-2xl text-balance text-lg leading-relaxed text-fog sm:text-xl">
      {profile.tagline} I ship things that people actually use - clean code, sharp UX,
      and a stubborn refusal to ship anything half-finished.
    </p>

    <!-- CTA row -->
    <div class="hero-rise hero-rise-d4 mt-10 flex flex-wrap items-center gap-3">
      <a
        href="#projects"
        class="magnetic group relative inline-flex items-center gap-2 overflow-hidden rounded-full bg-paper px-5 py-3 text-sm font-medium text-ink transition-transform hover:scale-[1.02]"
        data-magnetic
      >
        <span class="relative z-10">See my work</span>
        <svg
          class="relative z-10 transition-transform duration-500 group-hover:translate-x-0.5"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14M13 5l7 7-7 7"></path>
        </svg>
        <span
          class="absolute inset-0 -z-0 opacity-0 transition-opacity duration-500 group-hover:opacity-100"
          style="background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-2) 100%);"
        ></span>
      </a>

      <a
        href={profile.socials.email}
        class="magnetic inline-flex items-center gap-2 rounded-full border border-line px-5 py-3 text-sm font-medium text-paper transition-colors hover:border-line-strong hover:bg-white/[0.03]"
        data-magnetic
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="5" width="18" height="14" rx="2"></rect>
          <path d="m3 7 9 6 9-6"></path>
        </svg>
        Get in touch
      </a>
    </div>

    <!-- Status row -->
    <div class="hero-rise hero-rise-d5 mt-16 flex flex-wrap items-center gap-x-6 gap-y-3 text-[13px] text-fog">
      <div class="flex items-center gap-2">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-60"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-400"></span>
        </span>
        <span>{profile.current}</span>
      </div>
      <span class="hidden h-3 w-px bg-line sm:block"></span>
      <span class="font-mono text-mist">{profile.domain}</span>
    </div>
  </div>

  <!-- Scroll cue -->
  <div
    class="hero-rise hero-rise-d5 absolute bottom-6 left-1/2 hidden -translate-x-1/2 flex-col items-center gap-2 text-[11px] uppercase tracking-[0.2em] text-fog sm:flex"
    aria-hidden="true"
  >
    <span>scroll</span>
    <span class="relative block h-9 w-px overflow-hidden bg-line">
      <span class="absolute inset-x-0 top-0 h-3 animate-[scrollDot_1.8s_var(--ease-out-quart)_infinite] bg-paper"></span>
    </span>
  </div>
</section>

<style>
  @keyframes scrollDot {
    0%   { transform: translateY(-100%); opacity: 0; }
    35%  { opacity: 1; }
    100% { transform: translateY(360%); opacity: 0; }
  }
</style>