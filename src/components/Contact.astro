---
import { profile } from '../data/profile';

const socials = [
  {
    label: 'GitHub',
    href: profile.socials.github,
    icon: 'M12 .5C5.7.5.6 5.6.6 11.9c0 5 3.2 9.2 7.7 10.7.6.1.8-.2.8-.6v-2.2c-3.1.7-3.8-1.4-3.8-1.4-.5-1.3-1.2-1.7-1.2-1.7-1-.7.1-.7.1-.7 1.1.1 1.7 1.2 1.7 1.2 1 1.7 2.6 1.2 3.3.9.1-.7.4-1.2.7-1.5-2.5-.3-5.1-1.2-5.1-5.5 0-1.2.4-2.2 1.2-3-.1-.3-.5-1.5.1-3 0 0 1-.3 3.2 1.1.9-.3 1.9-.4 2.9-.4s2 .1 2.9.4c2.2-1.5 3.2-1.1 3.2-1.1.6 1.6.2 2.8.1 3 .7.8 1.2 1.8 1.2 3 0 4.3-2.6 5.2-5.1 5.5.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.5-1.5 7.7-5.7 7.7-10.7C23.4 5.6 18.3.5 12 .5z',
  },
  {
    label: 'Email',
    href: profile.socials.email,
    icon: 'M3 5h18a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1zm0 2 9 6 9-6',
  },
  {
    label: 'LinkedIn',
    href: profile.socials.linkedin,
    icon: 'M4 4h4v16H4zM6 2.4a2.4 2.4 0 1 1 0 4.8 2.4 2.4 0 0 1 0-4.8zM10 8h4v2.2c.6-1 2-2.4 4.5-2.4 4 0 4.5 3 4.5 6V20h-4v-5.4c0-1.5 0-3.4-2-3.4s-2.4 1.6-2.4 3.3V20h-4z',
  },
  {
    label: 'Twitter',
    href: profile.socials.twitter,
    icon: 'M18.9 5.4h3.3l-7.2 8.2L23.5 22h-6.6l-5.2-6.4L5.8 22H2.5l7.7-8.8L1.7 5.4h6.8l4.7 5.9 5.7-5.9zm-1.2 14.6h1.8L7.6 7H5.7l12 13z',
  },
];
---

<section id="contact" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-6 sm:px-8">
    <!-- Centerpiece card -->
    <div class="reveal relative isolate mx-auto max-w-4xl overflow-hidden rounded-3xl border border-line bg-white/[0.015] px-6 py-16 text-center sm:px-12 sm:py-20">
      <!-- Glow -->
      <div
        aria-hidden="true"
        class="pointer-events-none absolute left-1/2 top-0 -z-10 h-64 w-[640px] -translate-x-1/2 rounded-full opacity-70 blur-3xl"
        style="background: radial-gradient(closest-side, color-mix(in oklab, var(--color-accent) 40%, transparent), transparent 70%);"
      ></div>

      <p class="font-mono text-xs uppercase tracking-[0.2em] text-fog">
        <span class="text-accent">03.</span> Contact
      </p>

      <h2 class="mt-4 text-balance text-5xl font-semibold leading-[1.05] tracking-tight sm:text-7xl">
        Let's build<br />
        <span class="gradient-text">something good.</span>
      </h2>

      <p class="mx-auto mt-6 max-w-xl text-balance text-[17px] leading-relaxed text-fog">
        Open to interesting collaborations, contract work, and conversations
        about systems, tooling, or anything in between.
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
        <a
          href={profile.socials.email}
          class="magnetic group relative inline-flex items-center gap-2 overflow-hidden rounded-full bg-paper px-6 py-3.5 text-sm font-medium text-ink transition-transform hover:scale-[1.03]"
          data-magnetic
        >
          <span class="relative z-10">{profile.socials.email.replace('mailto:', '')}</span>
          <svg
            class="relative z-10 transition-transform duration-500 group-hover:translate-x-0.5"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M5 12h14M13 5l7 7-7 7" />
          </svg>
          <span
            class="absolute inset-0 -z-0 opacity-0 transition-opacity duration-500 group-hover:opacity-100"
            style="background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-2) 100%);"
          ></span>
        </a>

        <span class="font-mono text-xs text-mist">or find me on</span>
      </div>

      <!-- Social row -->
      <ul class="mt-8 flex flex-wrap items-center justify-center gap-2">
        {
          socials.map((s) => (
            <li>
              <a
                href={s.href}
                target={s.href.startsWith('http') ? '_blank' : undefined}
                rel={s.href.startsWith('http') ? 'noopener' : undefined}
                class="magnetic group inline-flex items-center gap-2 rounded-full border border-line bg-white/[0.02] px-4 py-2 text-[13px] text-paper transition-all hover:border-line-strong hover:bg-white/[0.05]"
                data-magnetic
              >
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d={s.icon} />
                </svg>
                <span>{s.label}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>