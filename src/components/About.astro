---
import { profile } from '../data/profile';

// Double the stack for a seamless marquee loop
const marqueeItems = [...profile.stack, ...profile.stack];

const highlights = [
  { label: 'Years building', value: '8+' },
  { label: 'Open-source repos', value: '40+' },
  { label: 'Coffee this week', value: '∞' },
  { label: 'Lines committed', value: '200k' },
];
---

<section id="about" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-6 sm:px-8">
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
      <!-- Heading -->
      <div class="reveal lg:col-span-5">
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-fog">
          <span class="text-accent">02.</span> About
        </p>
        <h2 class="mt-3 text-4xl font-semibold tracking-tight sm:text-5xl">
          The person<br />
          <span class="gradient-text">behind the code.</span>
        </h2>
      </div>

      <!-- Body -->
      <div class="reveal lg:col-span-7">
        <div class="space-y-5 text-[17px] leading-relaxed text-fog">
          <p class="text-balance text-paper">
            I'm <span class="text-paper">{profile.name}</span> - a coder who likes
            building tools that make other developers' lives easier.
          </p>
          <p>
            My background spans systems work (Java/Kotlin server backends),
            web development (TypeScript end-to-end), and a long-running love
            affair with the terminal. I care about clean abstractions, fast
            feedback loops, and software that respects the user's time.
          </p>
          <p>
            When I'm not shipping, I'm reading papers I barely understand,
            tweaking my dotfiles for the hundredth time, or losing at chess
            online.
          </p>
        </div>

        <!-- Highlights -->
        <dl class="mt-10 grid grid-cols-2 gap-x-6 gap-y-4 sm:grid-cols-4">
          {
            highlights.map((h) => (
              <div class="border-t border-line pt-3">
                <dt class="font-mono text-[11px] uppercase tracking-wider text-fog">
                  {h.label}
                </dt>
                <dd class="mt-1 text-2xl font-semibold tracking-tight">
                  {h.value}
                </dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>

    <!-- Tech marquee -->
    <div class="reveal mt-24 overflow-hidden border-y border-line py-6">
      <div class="flex items-center gap-3 font-mono text-xs uppercase tracking-[0.2em] text-fog">
        <span>stack</span>
        <span class="h-px flex-1 bg-line"></span>
        <span>{profile.stack.length}+ tools</span>
      </div>

      <div
        class="mt-6 flex w-max gap-3 marquee-track"
        style="will-change: transform;"
        aria-hidden="true"
      >
        {
          marqueeItems.map((s, i) => (
            <span
              class={`inline-flex shrink-0 items-center rounded-full border border-line bg-white/[0.02] px-4 py-2 font-mono text-[13px] ${i % 2 === 0 ? 'text-paper' : 'text-fog'}`}
            >
              {s}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>